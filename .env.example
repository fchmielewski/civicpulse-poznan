# CivicPulse — environment configuration.
# Copy this file to `.env` and fill in your keys.

# TomTom Traffic API key — required for the CAR TRAFFIC layer.
# Get a free key at https://developer.tomtom.com (free tier: 2,500 traffic
# tile requests/day). Must be prefixed with VITE_ to be exposed to the
# browser by Vite.
VITE_TOMTOM_API_KEY= 19595549
